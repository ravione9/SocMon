NODE_ENV=development
PORT=5000
JWT_SECRET=your_secret_here
MONGO_URI=mongodb://admin:netpulse_dev@mongo:27017/netpulse?authSource=admin
REDIS_URL=redis://:netpulse_dev@redis:6379
ES_HOST=https://192.168.24.180:9200
ES_USER=elastic
ES_PASSWORD=your_es_password
# SentinelOne / XDR documents (optional)
ES_SENTINEL_INDEX=sentinel-*
ES_CA_CERT_PATH=./certs/elasticsearch-ca.pem
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://ollama:11434
# Comma-separated for multiple frontends. If you list only localhost:3000 or only 127.0.0.1:3000, the server adds the other loopback automatically.
CORS_ORIGIN=http://localhost:3000

# Zabbix (Infra Monitoring) — API token (Administration → API tokens)
# Full JSON-RPC URL (404 = wrong path — try /zabbix/api_jsonrpc.php)
ZABBIX_URL=http://192.168.24.188/zabbix/api_jsonrpc.php
ZABBIX_API_TOKEN=
# Or ZABBIX_TOKEN= (alias)
# auto | bearer | body — use bearer for Zabbix 7.4+
#ZABBIX_AUTH=auto
# ZABBIX_TLS_INSECURE=1
