# Same-origin (recommended): leave empty so /api and /socket.io go through Vite dev proxy or nginx.
# Direct API: prefer http://127.0.0.1:5000 on Windows + Docker Desktop (localhost / ::1 often resets).
# VITE_API_URL=http://127.0.0.1:5000
VITE_API_URL=
# When using the proxy: backend URL (default http://127.0.0.1:5000). In Docker-only dev with Vite
# inside the same compose network and no VITE_API_URL, set VITE_DEV_PROXY_TARGET=http://server:5000
# VITE_DEV_PROXY_TARGET=
# Optional; empty = socket.io uses the page origin (works with proxy/nginx).
VITE_WS_URL=
VITE_APP_NAME=Lenskart
